---
/**
 * Site navigation.
 *
 * Desktop (>= 48rem): a sticky hairline top bar. The eye starts top-left on a
 * wide screen and a floating bottom bar there reads as a mobile pattern out of
 * place.
 *
 * Mobile (< 48rem): a floating bottom bar in the thumb zone. Recruiters open
 * this site from LinkedIn on a phone, one-handed. Icons carry a visible text
 * label underneath: icon-only navigation is guesswork and fails WCAG 2.5.3
 * (Label in Name) unless the accessible name matches what the user sees.
 *
 * Language switcher: lives in the header row, so it is visible at every width
 * (the header stays on mobile; only its link list moves to the bottom bar). The
 * bottom bar is a five-column grid in the thumb zone and a sixth item would
 * crush the labels. The switcher always points at the SAME page in the other
 * language, never at the home page.
 */
import { localeFromPath, localizedPath, pathInLocale, t } from "../i18n";
import { NAV_ITEMS, ui } from "../data/ui";
import type { NavItem } from "../data/ui";

const path = Astro.url.pathname;
const lang = localeFromPath(path);
const other = lang === "en" ? "es" : "en";

/** Path with the /es prefix removed, so the match rules stay language-agnostic. */
const basePath = path.replace(/^\/es(?=\/|$)/, "") || "/";

const otherLangHref = pathInLocale(path, other);

function isCurrent(item: NavItem): boolean {
  if (item.match === "/") return basePath === "/";
  return basePath.startsWith(item.match);
}
---

<header class="site-header">
  <div class="wrap site-header__row">
    <a href={localizedPath("/", lang)} class="site-header__name">
      Marius Mihail Ion
      <span class="site-header__role">{t(ui.siteRole, lang)}</span>
    </a>

    <div class="site-header__end">
      <nav class="topnav" aria-label={t(ui.navPrimary, lang)}>
        <ul class="topnav__list">
          {
            NAV_ITEMS.filter((item) => item.href !== "/").map((item) => (
              <li>
                <a
                  href={localizedPath(item.href, lang)}
                  class="topnav__link"
                  aria-current={isCurrent(item) ? "page" : undefined}
                >
                  {t(item.label, lang)}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <a
        class="langswitch"
        href={otherLangHref}
        hreflang={other}
        lang={other}
        aria-label={t(ui.languageSwitchTo, lang)}
      >
        <span class="langswitch__code">{t(ui.languageSwitchText, lang)}</span>
      </a>
    </div>
  </div>
</header>

<!--
  The same destinations as the top bar, rendered for the thumb zone. Only one of
  the two is ever display:block, so exactly one is in the tab order and in the
  landmark tree at any width. The labels differ so the two never collide.
-->
<nav class="bottomnav" aria-label={t(ui.navPrimaryBottom, lang)}>
  <ul class="bottomnav__list">
    {
      NAV_ITEMS.map((item) => (
        <li class="bottomnav__item">
          <a
            href={localizedPath(item.href, lang)}
            class="bottomnav__link"
            aria-current={isCurrent(item) ? "page" : undefined}
          >
            <svg
              class="bottomnav__icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              focusable="false"
            >
              {item.icon === "home" && (
                <Fragment>
                  <path d="M3 10.5 12 3l9 7.5" />
                  <path d="M5.5 9.5V20h13V9.5" />
                </Fragment>
              )}
              {item.icon === "work" && (
                <Fragment>
                  <rect x="3" y="7" width="18" height="13" rx="1.5" />
                  <path d="M8.5 7V5.5A1.5 1.5 0 0 1 10 4h4a1.5 1.5 0 0 1 1.5 1.5V7" />
                  <path d="M3 12h18" />
                </Fragment>
              )}
              {item.icon === "experience" && (
                <Fragment>
                  <path d="M7 4v16" />
                  <circle cx="7" cy="8" r="1.6" />
                  <circle cx="7" cy="16" r="1.6" />
                  <path d="M11 8h9" />
                  <path d="M11 16h6" />
                </Fragment>
              )}
              {item.icon === "about" && (
                <Fragment>
                  <circle cx="12" cy="8" r="3.5" />
                  <path d="M4.5 20a7.5 7.5 0 0 1 15 0" />
                </Fragment>
              )}
              {item.icon === "contact" && (
                <Fragment>
                  <rect x="3" y="5.5" width="18" height="13" rx="1.5" />
                  <path d="m3.8 6.6 8.2 6 8.2-6" />
                </Fragment>
              )}
            </svg>
            <span class="bottomnav__label">{t(item.label, lang)}</span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  /* ---------------- Desktop: sticky top bar ---------------- */

  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--rule);
    background: color-mix(in srgb, var(--paper) 88%, transparent);
    backdrop-filter: saturate(140%) blur(8px);
  }

  .site-header__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding-block: var(--space-2);
    min-height: 4rem;
  }

  .site-header__end {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .site-header__name {
    display: grid;
    gap: 0.15rem;
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink);
    text-decoration: none;
    min-width: 0;
  }

  .site-header__role {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--slate);
  }

  .topnav__list {
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin: 0;
    padding: 0;
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }

  .topnav__link {
    position: relative;
    display: block;
    padding-block: 0.35rem;
    color: var(--slate);
    text-decoration: none;
  }

  .topnav__link:hover {
    color: var(--ink);
  }

  /* Active page: a rule under the label, not a color change alone. */
  .topnav__link[aria-current="page"] {
    color: var(--ink);
  }

  .topnav__link[aria-current="page"]::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.85rem;
    height: 2px;
    background: var(--steel);
  }

  /* ---------------- Language switcher ---------------- */

  .langswitch {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    /* 44px touch target: this is the one control a Spanish recruiter needs. */
    min-width: 2.75rem;
    min-height: 2.25rem;
    padding-inline: 0.6rem;
    border: 1px solid var(--rule-strong);
    border-radius: 999px;
    background: var(--paper-raised);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--slate);
    text-decoration: none;
    flex: none;
  }

  .langswitch:hover {
    border-color: var(--steel);
    color: var(--steel-dark);
    background: var(--steel-wash);
  }

  /* ---------------- Mobile: floating bottom bar ---------------- */

  .bottomnav {
    display: none;
  }

  @media (max-width: 47.999rem) {
    /* The top bar keeps the name and the language switcher, drops the links:
       the bottom bar owns them. */
    .topnav {
      display: none;
    }

    .site-header {
      position: static;
      backdrop-filter: none;
      background: var(--paper);
    }

    .site-header__row {
      min-height: 3.5rem;
      gap: var(--space-2);
    }

    .bottomnav {
      display: block;
      position: fixed;
      z-index: 60;
      left: 50%;
      transform: translateX(-50%);
      bottom: calc(0.75rem + env(safe-area-inset-bottom, 0px));
      width: min(calc(100% - 1.5rem), 26rem);
      background: var(--paper-raised);
      border: 1px solid var(--rule);
      border-radius: 14px;
      box-shadow: var(--shadow-raised);
    }

    .bottomnav__list {
      list-style: none;
      margin: 0;
      padding: 0.375rem;
      display: grid;
      grid-template-columns: repeat(5, 1fr);
    }

    .bottomnav__item {
      min-width: 0;
    }

    .bottomnav__link {
      display: grid;
      justify-items: center;
      gap: 0.2rem;
      /* 48px minimum touch target. */
      min-height: 3rem;
      /* The inline padding is 0: the Spanish labels are longer than the English
         ones ("Experiencia" is 11 characters) and any horizontal padding here
         clips them to an ellipsis at 390px. The 48px touch target is held by
         min-height and the grid column, not by padding. */
      padding: 0.4rem 0;
      border-radius: 10px;
      color: var(--slate);
      text-decoration: none;
    }

    .bottomnav__icon {
      width: 22px;
      height: 22px;
      flex: none;
    }

    .bottomnav__label {
      font-family: var(--font-mono);
      /* Fluid, because the Spanish labels are longer than the English ones and
         the bar is a fixed five-column grid. At 320px "Experiencia" (and even
         "Experience") no longer fits at 10px, and a clipped label breaks WCAG
         2.5.3: the visible text must match the accessible name. The floor is
         9px, still legible at arm's length on a phone. */
      font-size: clamp(0.5625rem, 0.4rem + 0.8vw, 0.625rem);
      letter-spacing: 0.01em;
      line-height: 1.1;
      max-width: 100%;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .bottomnav__link[aria-current="page"] {
      color: var(--steel-dark);
      background: var(--steel-wash);
    }
  }
</style>
