---
/** The profile page, rendered once per language. */
import Layout from "../../layouts/Layout.astro";
import { aboutParagraphs, ui } from "../../data/ui";
import { t, type Locale } from "../../i18n";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
---

<Layout
  title={t(ui.aboutTitle, lang)}
  description={t(ui.aboutDescription, lang)}
>
  <div class="wrap wrap--narrow page">
    <header class="page-head">
      <p class="eyebrow">{t(ui.aboutEyebrow, lang)}</p>
      {/* Every page needs one h1; the page name is it. */}
      <h1>{t(ui.aboutHeading, lang)}</h1>
    </header>

    <section class="about" aria-label={t(ui.aboutAriaLabel, lang)}>
      <div class="about__body prose">
        {aboutParagraphs.map((p) => <p>{t(p, lang)}</p>)}
      </div>
      <a class="btn" href="/marius-mihail-ion-cv.pdf">{t(ui.heroCtaCv, lang)}</a>
    </section>
  </div>
</Layout>

<style>
  .page {
    padding-bottom: var(--space-5);
  }

  .page-head {
    padding-bottom: var(--space-3);
  }

  .about__body {
    display: grid;
    gap: var(--space-3);
    /* The first paragraph is the thesis: it reads a size larger. */
    font-size: var(--step-lede);
  }

  .about__body p:first-child {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 1.15rem + 1vw, 1.75rem);
    line-height: 1.35;
    color: var(--ink);
  }

  .about__body p:not(:first-child) {
    color: var(--slate);
  }

  .about .btn {
    margin-top: var(--space-4);
  }
</style>
