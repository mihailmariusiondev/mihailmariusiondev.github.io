---
/**
 * The home page, rendered once per language.
 *
 * The markup lives here, not in the route files, so `/` and `/es/` cannot drift
 * structurally: there is exactly one template and two thin route wrappers. A
 * section that exists in Spanish but not in English is impossible by
 * construction, and every string comes from a `Localized<T>` object that fails
 * `astro check` if a language is missing.
 */
import Layout from "../../layouts/Layout.astro";
import CaseStudyCard from "../CaseStudyCard.astro";
import { caseStudies } from "../../data/caseStudies";
import { stats } from "../../data/experience";
import { ui } from "../../data/ui";
import { localizedPath, t, type Locale } from "../../i18n";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
---

<Layout
  title={t(ui.homeTitle, lang)}
  description={t(ui.homeDescription, lang)}
  ogTitle={t(ui.homeOgTitle, lang)}
  ogDescription={t(ui.homeOgDescription, lang)}
>
  <section class="hero">
    <div class="wrap hero__grid">
      <figure class="hero__figure">
        <img
          class="hero__photo"
          src="/me.webp"
          alt={t(ui.heroPhotoAlt, lang)}
          width="640"
          height="640"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </figure>

      <div class="hero__body">
        <p class="eyebrow">{t(ui.siteRole, lang)}</p>
        <h1 class="hero__title">{t(ui.heroTitle, lang)}</h1>
        <p class="hero__lede">{t(ui.heroLede, lang)}</p>
        <div class="hero__actions">
          <a class="btn btn-primary" href={localizedPath("/case-studies/", lang)}>
            {t(ui.heroCtaCases, lang)}
          </a>
          <a class="btn" href="/marius-mihail-ion-cv.pdf">
            {t(ui.heroCtaCv, lang)}
          </a>
          <a class="btn" href="https://linkedin.com/in/mariusdev">LinkedIn</a>
          <a class="btn" href="https://github.com/mihailmariusiondev">GitHub</a>
        </div>
        <p class="hero__location">{t(ui.heroLocation, lang)}</p>
      </div>
    </div>
  </section>

  <section class="stats" aria-labelledby="stats-heading">
    <div class="wrap">
      <h2 id="stats-heading" class="stats__heading eyebrow">
        {t(ui.statsHeading, lang)}
      </h2>
      <ul class="stats__list">
        {
          stats.map((stat) => (
            <li class="stat">
              <p class="stat__value">{t(stat.value, lang)}</p>
              <p class="stat__label">{t(stat.label, lang)}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section id="work" class="work">
    <div class="wrap">
      <div class="work__head">
        <h2 class="work__title">{t(ui.workTitle, lang)}</h2>
        <p class="work__lede prose">{t(ui.workLede, lang)}</p>
      </div>
      <div class="work__grid">
        {caseStudies.map((study) => <CaseStudyCard study={study} />)}
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ---------------- Hero ---------------- */

  .hero {
    padding-block: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--rule);
  }

  .hero__grid {
    display: grid;
    gap: var(--space-4);
    align-items: start;
  }

  @media (min-width: 56rem) {
    .hero__grid {
      /* Text first in the source order and in the visual order on desktop. */
      grid-template-columns: minmax(0, 1fr) 14rem;
      gap: var(--space-5);
    }
    .hero__figure {
      order: 2;
    }
    .hero__body {
      order: 1;
    }
  }

  .hero__figure {
    margin: 0;
    /* On mobile the portrait is centred above the text, not floated beside it. */
    justify-self: center;
    width: min(11rem, 45vw);
  }

  @media (min-width: 56rem) {
    .hero__figure {
      justify-self: end;
      width: 100%;
      max-width: 14rem;
    }
  }

  .hero__photo {
    display: block;
    width: 100%;
    /* height:auto is load-bearing. The img carries width/height attributes (for
       CLS), and aspect-ratio is ignored unless the other axis is auto: without
       this the picture renders 176x640. */
    height: auto;
    /* Square frame. The source is a standing shot: a circle crops to the
       forearms and a 4:5 frame towers over the text column. */
    aspect-ratio: 1 / 1;
    object-fit: cover;
    /* The head sits in the upper third of the 640x640 source. Raise the crop
       to it, but not so far that the top of the head is cut. */
    object-position: 50% 22%;
    border-radius: var(--radius);
    border: 1px solid var(--rule);
    background: var(--paper-raised);
    box-shadow: var(--shadow-raised);
  }

  .hero__title {
    font-size: var(--step-display);
    max-width: 20ch;
    margin-block: var(--space-2) var(--space-3);
  }

  .hero__lede {
    max-width: 54ch;
    font-size: var(--step-lede);
    color: var(--slate);
    margin-bottom: var(--space-3);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: var(--space-3);
  }

  .hero__location {
    font-family: var(--font-mono);
    font-size: var(--step-micro);
    line-height: 1.6;
    color: var(--slate-quiet);
    max-width: 48ch;
  }

  /* ---------------- Verified results ---------------- */

  .stats {
    padding-block: var(--space-4);
    background: var(--paper-sunk);
    border-bottom: 1px solid var(--rule);
  }

  .stats__heading {
    margin-bottom: var(--space-3);
  }

  .stats__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-3);
  }

  @media (min-width: 40rem) {
    .stats__list {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-3) var(--space-4);
    }
  }

  @media (min-width: 64rem) {
    .stats__list {
      /* The five figures read as one measured ledger, not five loose cards. */
      grid-template-columns: repeat(5, 1fr);
    }
  }

  .stat {
    /* The rule is the signature: each figure is an audited entry, not a badge. */
    border-left: 2px solid var(--steel);
    padding-left: var(--space-2);
    min-width: 0;
  }

  .stat__value {
    font-family: var(--font-mono);
    font-size: 1.625rem;
    font-weight: 500;
    line-height: 1.2;
    color: var(--steel-dark);
    margin-bottom: 0.4rem;
    overflow-wrap: break-word;
  }

  .stat__label {
    font-size: var(--step-small);
    line-height: 1.5;
    color: var(--slate);
    max-width: 40ch;
  }

  /* ---------------- Case studies ---------------- */

  .work {
    padding-block: var(--space-5);
  }

  .work__head {
    margin-bottom: var(--space-4);
  }

  .work__title {
    font-size: var(--step-h2);
    margin-bottom: var(--space-1);
  }

  .work__lede {
    color: var(--slate);
  }

  .work__grid {
    display: grid;
    gap: var(--space-3);
  }

  @media (min-width: 56rem) {
    .work__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
